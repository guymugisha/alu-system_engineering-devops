#!/usr/bin/env bash
# Configures a new Ubuntu machine with X-Served-By header and standard content

apt-get update -y
apt-get install -y nginx

# Set custom index content (Required for previous web server tasks)
echo "Holberton School" | tee /var/www/html/index.html > /dev/null

# Set custom 404 page content
echo "Ceci n'est pas une page" | tee /var/www/html/404.html > /dev/null

# Add the X-Served-By header to the default site configuration
# We use the Nginx variable $(hostname) to ensure the correct value is always returned
sed -i "/server_name _;/a \	add_header X-Served-By \"$(hostname)\";" /etc/nginx/sites-available/default

# Restart Nginx to apply changes
service nginx restart
